---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import CategoryLanding from '@/components/pages/CategoryLanding';
import { buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { PYTHON_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(PYTHON_SECTION.collections.patterns),
    getCollection(PYTHON_SECTION.collections.philosophy),
    getCollection(PYTHON_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, PYTHON_SECTION);

  return categories.map((category) => {
    const catKey = category.id.replace(/\/index$/, '');
    const catPatterns = patterns
      .filter((pattern) => pattern.data.category === catKey)
      .map((pattern) => ({
        slug: pattern.id.replace(/\.md$/, '').split('/')[1],
        title: pattern.data.title,
        category: pattern.data.category,
        intent: pattern.data.intent,
        summary: getPatternSummary(pattern),
      }));

    return {
      params: { category: catKey },
      props: {
        category: { slug: catKey, title: category.data.title, lede: category.data.lede },
        introMarkdown: category.body,
        patterns: catPatterns,
        navOrder,
      },
    };
  });
}

const { category, introMarkdown, patterns, navOrder } = Astro.props;
---

<SiteLayout
  title={category.title}
  description={category.lede}
  basePath={PYTHON_SECTION.basePath}
  sectionLabel={PYTHON_SECTION.label}
  themeStorageKey={PYTHON_SECTION.themeStorageKey}
  categoryOrder={PYTHON_SECTION.categoryOrder}
  philosophyOrder={PYTHON_SECTION.philosophyOrder}
  collections={PYTHON_SECTION.collections}
>
  <CategoryLanding
    category={category}
    introMarkdown={introMarkdown}
    patterns={patterns}
    navOrder={navOrder}
    pathname={`${PYTHON_SECTION.basePath}/patterns/${category.slug}`}
    basePath={PYTHON_SECTION.basePath}
    summaryLabel={PYTHON_SECTION.summaryLabel}
    client:load
  />
</SiteLayout>
