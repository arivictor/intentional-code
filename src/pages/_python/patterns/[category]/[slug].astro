---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PatternPage from '@/components/pages/PatternPage';
import { buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { PYTHON_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(PYTHON_SECTION.collections.patterns),
    getCollection(PYTHON_SECTION.collections.philosophy),
    getCollection(PYTHON_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, PYTHON_SECTION);

  const allPatterns = patterns.map((pattern) => ({
    slug: pattern.id.replace(/\.md$/, '').split('/')[1],
    title: pattern.data.title,
    category: pattern.data.category,
    intent: pattern.data.intent,
    summary: getPatternSummary(pattern),
    relatedSlugs: pattern.data.relatedSlugs,
  }));

  return patterns.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').split('/')[1];
    return {
      params: { category: entry.data.category, slug },
      props: {
        pattern: {
          slug,
          storageKey: `${PYTHON_SECTION.basePath}/patterns/${entry.data.category}/${slug}`,
          title: entry.data.title,
          category: entry.data.category,
          intent: entry.data.intent,
          summary: getPatternSummary(entry),
          relatedSlugs: entry.data.relatedSlugs,
          basePath: PYTHON_SECTION.basePath,
        },
        markdown: entry.body,
        allPatterns,
        navOrder,
      },
    };
  });
}

const { pattern, markdown, allPatterns, navOrder } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  name: `${pattern.title} Pattern in ${PYTHON_SECTION.label}`,
  description: pattern.intent,
  url: `https://intentionalcode.com${PYTHON_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`,
  publisher: { '@type': 'Organization', name: 'Intentional Code' },
};
---

<SiteLayout
  title={pattern.title}
  description={pattern.intent}
  jsonLd={jsonLd}
  basePath={PYTHON_SECTION.basePath}
  sectionLabel={PYTHON_SECTION.label}
  themeStorageKey={PYTHON_SECTION.themeStorageKey}
  categoryOrder={PYTHON_SECTION.categoryOrder}
  philosophyOrder={PYTHON_SECTION.philosophyOrder}
  collections={PYTHON_SECTION.collections}
>
  <PatternPage
    pattern={pattern}
    markdown={markdown}
    allPatterns={allPatterns}
    navOrder={navOrder}
    pathname={`${PYTHON_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`}
    client:load
  />
</SiteLayout>
