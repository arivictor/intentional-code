---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import Home from '@/components/pages/Home';
import { buildAllContent, buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { GO_SECTION } from '@/lib/section-config';

const [patterns, philosophy, categories, sitePages] = await Promise.all([
  getCollection(GO_SECTION.collections.patterns),
  getCollection(GO_SECTION.collections.philosophy),
  getCollection(GO_SECTION.collections.categories),
  getCollection(GO_SECTION.collections.pages),
]);

const homePage = sitePages.find((entry) => entry.id === 'home');

const allContent = buildAllContent(patterns, philosophy, { basePath: GO_SECTION.basePath });
const navOrder = buildNavOrder(patterns, philosophy, categories, {
  basePath: GO_SECTION.basePath,
  homePath: GO_SECTION.homePath,
  categoryOrder: GO_SECTION.categoryOrder,
  philosophyOrder: GO_SECTION.philosophyOrder,
});

const categoriesData = GO_SECTION.categoryOrder.map((key) => {
  const category = categories.find((entry) => entry.id.replace(/\/index$/, '') === key);
  return { slug: key, title: category?.data.title ?? key, lede: category?.data.lede ?? '' };
});

const patternsData = patterns.map((entry) => {
  const slug = entry.id.replace(/\.md$/, '').split('/')[1];
  return {
    slug,
    storageKey: `${GO_SECTION.basePath}/patterns/${entry.data.category}/${slug}`,
    title: entry.data.title,
    category: entry.data.category,
    intent: entry.data.intent,
    summary: getPatternSummary(entry),
    tags: entry.data.tags,
    isFeatured: entry.data.isFeatured,
  };
});

const allTags = [...new Set(patterns.flatMap((entry) => entry.data.tags))].sort();

const philosophyData = philosophy.map((entry) => {
  const isIndex = entry.id === 'index';
  return {
    slug: entry.id,
    storageKey: isIndex ? `${GO_SECTION.basePath}/philosophy` : `${GO_SECTION.basePath}/philosophy/${entry.id}`,
    title: entry.data.title,
    description: isIndex ? entry.data.intro : entry.data.description,
    url: isIndex ? `${GO_SECTION.basePath}/philosophy` : `${GO_SECTION.basePath}/philosophy/${entry.id}`,
  };
});
---

<SiteLayout
  title={GO_SECTION.homeTitle}
  description={GO_SECTION.homeDescription}
  basePath={GO_SECTION.basePath}
  homePath={GO_SECTION.homePath}
  sectionLabel={GO_SECTION.label}
  themeStorageKey={GO_SECTION.themeStorageKey}
  categoryOrder={GO_SECTION.categoryOrder}
  philosophyOrder={GO_SECTION.philosophyOrder}
  collections={GO_SECTION.collections}
>
  <Home
    allContent={allContent}
    navOrder={navOrder}
    categories={categoriesData}
    categoryOrder={GO_SECTION.categoryOrder}
    patterns={patternsData}
    philosophy={philosophyData}
    pathname={GO_SECTION.homePath}
    tagline={homePage?.data.tagline}
    heroBody={homePage?.body}
    catalogHeading={homePage?.data.catalogHeading}
    allTags={allTags}
    basePath={GO_SECTION.basePath}
    languageLabel={GO_SECTION.label}
    client:load
  />
</SiteLayout>
