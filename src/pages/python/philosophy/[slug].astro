---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PhilosophyDetailPage from '@/components/pages/PhilosophyDetailPage';
import { buildNavOrder } from '@/lib/site-data';
import { getCollectionNames, getLanguageConfig } from '@/lib/languages';

const language = 'python';
const languageConfig = getLanguageConfig(language);
const collectionNames = getCollectionNames(language);

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(collectionNames.patterns),
    getCollection(collectionNames.philosophy),
    getCollection(collectionNames.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, languageConfig.basePath);

  return philosophy.filter((entry) => entry.id !== 'index').map((entry) => {
    const slug = entry.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: {
        slug,
        title: entry.data.title,
        description: entry.data.description,
        markdown: entry.body,
        storageKey: `${languageConfig.basePath}/philosophy/${slug}`,
        navOrder,
      },
    };
  });
}

const { slug, title, description, markdown, storageKey, navOrder } = Astro.props;
---

<SiteLayout title={title} description={description} language={language}>
  <PhilosophyDetailPage
    slug={slug}
    title={title}
    description={description}
    markdown={markdown}
    storageKey={storageKey}
    navOrder={navOrder}
    pathname={`${languageConfig.basePath}/philosophy/${slug}`}
    client:load
  />
</SiteLayout>
