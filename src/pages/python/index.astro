---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import Home from '@/components/pages/Home';
import { buildAllContent, buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { PYTHON_SECTION } from '@/lib/section-config';

const [patterns, philosophy, categories, sitePages] = await Promise.all([
  getCollection(PYTHON_SECTION.collections.patterns),
  getCollection(PYTHON_SECTION.collections.philosophy),
  getCollection(PYTHON_SECTION.collections.categories),
  getCollection(PYTHON_SECTION.collections.pages),
]);

const homePage = sitePages.find((entry) => entry.id === 'home');

const allContent = buildAllContent(patterns, philosophy, { basePath: PYTHON_SECTION.basePath });
const navOrder = buildNavOrder(patterns, philosophy, categories, PYTHON_SECTION);

const categoriesData = PYTHON_SECTION.categoryOrder.map((key) => {
  const category = categories.find((entry) => entry.id.replace(/\/index$/, '') === key);
  return { slug: key, title: category?.data.title ?? key, lede: category?.data.lede ?? '' };
});

const patternsData = patterns.map((entry) => {
  const slug = entry.id.replace(/\.md$/, '').split('/')[1];
  return {
    slug,
    storageKey: `${PYTHON_SECTION.basePath}/patterns/${entry.data.category}/${slug}`,
    title: entry.data.title,
    category: entry.data.category,
    intent: entry.data.intent,
    summary: getPatternSummary(entry),
    tags: entry.data.tags,
    isFeatured: entry.data.isFeatured,
  };
});

const allTags = [...new Set(patterns.flatMap((entry) => entry.data.tags))].sort();

const philosophyData = philosophy.map((entry) => {
  const isIndex = entry.id === 'index';
  return {
    slug: entry.id,
    storageKey: isIndex ? `${PYTHON_SECTION.basePath}/philosophy` : `${PYTHON_SECTION.basePath}/philosophy/${entry.id}`,
    title: entry.data.title,
    description: isIndex ? entry.data.intro : entry.data.description,
    url: isIndex ? `${PYTHON_SECTION.basePath}/philosophy` : `${PYTHON_SECTION.basePath}/philosophy/${entry.id}`,
  };
});
---

<SiteLayout
  title={PYTHON_SECTION.homeTitle}
  description={PYTHON_SECTION.homeDescription}
  basePath={PYTHON_SECTION.basePath}
  sectionLabel={PYTHON_SECTION.label}
  themeStorageKey={PYTHON_SECTION.themeStorageKey}
  categoryOrder={PYTHON_SECTION.categoryOrder}
  philosophyOrder={PYTHON_SECTION.philosophyOrder}
  collections={PYTHON_SECTION.collections}
>
  <Home
    allContent={allContent}
    navOrder={navOrder}
    categories={categoriesData}
    categoryOrder={PYTHON_SECTION.categoryOrder}
    patterns={patternsData}
    philosophy={philosophyData}
    pathname={PYTHON_SECTION.basePath}
    tagline={homePage?.data.tagline}
    heroBody={homePage?.body}
    catalogHeading={homePage?.data.catalogHeading}
    allTags={allTags}
    basePath={PYTHON_SECTION.basePath}
    languageLabel={PYTHON_SECTION.label}
    client:load
  />
</SiteLayout>
