---
import SiteLayout from '@/layouts/SiteLayout.astro';
---

<SiteLayout title="Page Not Found">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <p class="text-xl text-muted-foreground mb-8">Page not found.</p>
    <a href="/go" class="inline-flex items-center px-4 py-2 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
      Back to home
    </a>
  </div>
</SiteLayout>
