---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PatternFinder from '@/components/pages/PatternFinder';
import { buildAllContent, buildNavOrder } from '@/lib/site-data';
import { GO_SECTION } from '@/lib/section-config';

const [patterns, philosophy, categories] = await Promise.all([
  getCollection(GO_SECTION.collections.patterns),
  getCollection(GO_SECTION.collections.philosophy),
  getCollection(GO_SECTION.collections.categories),
]);

const allContent = buildAllContent(patterns, philosophy, { basePath: GO_SECTION.basePath });
const navOrder = buildNavOrder(patterns, philosophy, categories, GO_SECTION);

const patternIndex = patterns.map((p) => {
  const slug = p.id.split('/')[1];
  return {
    slug,
    title: p.data.title,
    category: p.data.category,
    intent: p.data.intent,
    path: `${GO_SECTION.basePath}/patterns/${p.data.category}/${slug}`,
  };
});
---

<SiteLayout
  title="Pattern Finder"
  description="Answer a few questions about your problem and get a pattern recommendation."
  basePath={GO_SECTION.basePath}
  sectionLabel={GO_SECTION.label}
  themeStorageKey={GO_SECTION.themeStorageKey}
  categoryOrder={GO_SECTION.categoryOrder}
  philosophyOrder={GO_SECTION.philosophyOrder}
  collections={GO_SECTION.collections}
>
  <PatternFinder
    patternIndex={patternIndex}
    allContent={allContent}
    navOrder={navOrder}
    basePath={GO_SECTION.basePath}
    pathname={`${GO_SECTION.basePath}/finder`}
    client:load
  />
</SiteLayout>
