---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PatternPage from '@/components/pages/PatternPage';
import { buildNavOrder } from '@/lib/site-data';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection('patterns'),
    getCollection('philosophy'),
    getCollection('pattern-categories'),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories);

  const allPatterns = patterns.map((p) => ({
    slug: p.id.replace(/\.md$/, '').split('/')[1],
    title: p.data.title,
    category: p.data.category,
    intent: p.data.intent,
    goIdiomSummary: p.data.goIdiomSummary,
    relatedSlugs: p.data.relatedSlugs,
  }));

  return patterns.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').split('/')[1];
    return {
      params: { category: entry.data.category, slug },
      props: {
        pattern: {
          slug,
          title: entry.data.title,
          category: entry.data.category,
          intent: entry.data.intent,
          goIdiomSummary: entry.data.goIdiomSummary,
          relatedSlugs: entry.data.relatedSlugs,
        },
        markdown: entry.body,
        allPatterns,
        navOrder,
      },
    };
  });
}

const { pattern, markdown, allPatterns, navOrder } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  name: `${pattern.title} Pattern in Go`,
  description: pattern.intent,
  url: `https://intentionalcode.com/go/patterns/${pattern.category}/${pattern.slug}`,
  publisher: { '@type': 'Organization', name: 'Intentional Code' },
};
---

<SiteLayout title={pattern.title} description={pattern.intent} jsonLd={jsonLd}>
  <PatternPage
    pattern={pattern}
    markdown={markdown}
    allPatterns={allPatterns}
    navOrder={navOrder}
    pathname={`/go/patterns/${pattern.category}/${pattern.slug}`}
    client:load
  />
</SiteLayout>
