---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PatternPage from '@/components/pages/PatternPage';
import { buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { GO_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(GO_SECTION.collections.patterns),
    getCollection(GO_SECTION.collections.philosophy),
    getCollection(GO_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, GO_SECTION);

  const allPatterns = patterns.map((pattern) => ({
    slug: pattern.id.replace(/\.md$/, '').split('/')[1],
    title: pattern.data.title,
    category: pattern.data.category,
    intent: pattern.data.intent,
    summary: getPatternSummary(pattern),
    relatedSlugs: pattern.data.relatedSlugs,
  }));

  return patterns.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').split('/')[1];
    return {
      params: { category: entry.data.category, slug },
      props: {
        pattern: {
          slug,
          storageKey: `${GO_SECTION.basePath}/patterns/${entry.data.category}/${slug}`,
          title: entry.data.title,
          category: entry.data.category,
          intent: entry.data.intent,
          summary: getPatternSummary(entry),
          relatedSlugs: entry.data.relatedSlugs,
          basePath: GO_SECTION.basePath,
        },
        markdown: entry.body,
        allPatterns,
        navOrder,
      },
    };
  });
}

const { pattern, markdown, allPatterns, navOrder } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  name: `${pattern.title} Pattern in ${GO_SECTION.label}`,
  description: pattern.intent,
  url: `https://intentionalcode.com${GO_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`,
  publisher: { '@type': 'Organization', name: 'Intentional Code' },
};
---

<SiteLayout
  title={pattern.title}
  description={pattern.intent}
  jsonLd={jsonLd}
  basePath={GO_SECTION.basePath}
  sectionLabel={GO_SECTION.label}
  themeStorageKey={GO_SECTION.themeStorageKey}
  categoryOrder={GO_SECTION.categoryOrder}
  philosophyOrder={GO_SECTION.philosophyOrder}
  collections={GO_SECTION.collections}
>
  <PatternPage
    pattern={pattern}
    markdown={markdown}
    allPatterns={allPatterns}
    navOrder={navOrder}
    pathname={`${GO_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`}
    client:load
  />
</SiteLayout>
