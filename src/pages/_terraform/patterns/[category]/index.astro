---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import CategoryLanding from '@/components/pages/CategoryLanding';
import { buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { TERRAFORM_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(TERRAFORM_SECTION.collections.patterns),
    getCollection(TERRAFORM_SECTION.collections.philosophy),
    getCollection(TERRAFORM_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, TERRAFORM_SECTION);

  return categories.map((cat) => {
    const catKey = cat.id.replace(/\/index$/, '');
    const catPatterns = patterns
      .filter((p) => p.data.category === catKey)
      .map((p) => ({
        slug: p.id.replace(/\.md$/, '').split('/')[1],
        title: p.data.title,
        category: p.data.category,
        intent: p.data.intent,
        summary: getPatternSummary(p),
      }));

    return {
      params: { category: catKey },
      props: {
        category: { slug: catKey, title: cat.data.title, lede: cat.data.lede },
        introMarkdown: cat.body,
        patterns: catPatterns,
        navOrder,
      },
    };
  });
}

const { category, introMarkdown, patterns, navOrder } = Astro.props;
---

<SiteLayout
  title={category.title}
  description={category.lede}
  basePath={TERRAFORM_SECTION.basePath}
  sectionLabel={TERRAFORM_SECTION.label}
  themeStorageKey={TERRAFORM_SECTION.themeStorageKey}
  categoryOrder={TERRAFORM_SECTION.categoryOrder}
  philosophyOrder={TERRAFORM_SECTION.philosophyOrder}
  collections={TERRAFORM_SECTION.collections}
>
  <CategoryLanding
    category={category}
    introMarkdown={introMarkdown}
    patterns={patterns}
    navOrder={navOrder}
    pathname={`${TERRAFORM_SECTION.basePath}/patterns/${category.slug}`}
    basePath={TERRAFORM_SECTION.basePath}
    summaryLabel={TERRAFORM_SECTION.summaryLabel}
    client:load
  />
</SiteLayout>
