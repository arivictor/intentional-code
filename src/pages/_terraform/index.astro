---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import Home from '@/components/pages/Home';
import { buildAllContent, buildNavOrder } from '@/lib/site-data';
import { TERRAFORM_SECTION } from '@/lib/section-config';

const [patterns, philosophy, categories, sitePages] = await Promise.all([
  getCollection(TERRAFORM_SECTION.collections.patterns),
  getCollection(TERRAFORM_SECTION.collections.philosophy),
  getCollection(TERRAFORM_SECTION.collections.categories),
  getCollection(TERRAFORM_SECTION.collections.pages),
]);

const homePage = sitePages.find((p) => p.id === 'home');

const allContent = buildAllContent(patterns, philosophy, { basePath: TERRAFORM_SECTION.basePath });
const navOrder = buildNavOrder(patterns, philosophy, categories, TERRAFORM_SECTION);

const categoriesData = TERRAFORM_SECTION.categoryOrder.map((key) => {
  const cat = categories.find((c) => c.id.replace(/\/index$/, '') === key);
  return { slug: key, title: cat?.data.title ?? key, lede: cat?.data.lede ?? '' };
});

const patternsData = patterns.map((p) => ({
  slug: p.id.replace(/\.md$/, '').split('/')[1],
  title: p.data.title,
  category: p.data.category,
  intent: p.data.intent,
  tags: p.data.tags,
  isFeatured: p.data.isFeatured,
}));

const allTags = [...new Set(patterns.flatMap((p) => p.data.tags))].sort();

const philosophyData = philosophy.map((p) => {
  const isIndex = p.id === 'index';
  return {
    slug: p.id,
    title: p.data.title,
    description: isIndex ? p.data.intro : p.data.description,
    url: isIndex ? `${TERRAFORM_SECTION.basePath}/philosophy` : `${TERRAFORM_SECTION.basePath}/philosophy/${p.id}`,
  };
});
---

<SiteLayout
  title="Terraform Patterns and Architecture"
  description="Terraform-specific patterns for modules, state, delivery, and platform architecture."
  basePath={TERRAFORM_SECTION.basePath}
  sectionLabel={TERRAFORM_SECTION.label}
  themeStorageKey={TERRAFORM_SECTION.themeStorageKey}
  categoryOrder={TERRAFORM_SECTION.categoryOrder}
  philosophyOrder={TERRAFORM_SECTION.philosophyOrder}
  collections={TERRAFORM_SECTION.collections}
>
  <Home
    allContent={allContent}
    navOrder={navOrder}
    categories={categoriesData}
    categoryOrder={TERRAFORM_SECTION.categoryOrder}
    patterns={patternsData}
    philosophy={philosophyData}
    pathname={TERRAFORM_SECTION.basePath}
    tagline={homePage?.data.tagline}
    heroBody={homePage?.body}
    catalogHeading={homePage?.data.catalogHeading}
    allTags={allTags}
    basePath={TERRAFORM_SECTION.basePath}
    languageLabel={TERRAFORM_SECTION.label}
    client:load
  />
</SiteLayout>
