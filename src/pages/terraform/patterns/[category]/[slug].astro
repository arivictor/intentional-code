---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PatternPage from '@/components/pages/PatternPage';
import { buildNavOrder, getPatternSummary } from '@/lib/site-data';
import { TERRAFORM_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(TERRAFORM_SECTION.collections.patterns),
    getCollection(TERRAFORM_SECTION.collections.philosophy),
    getCollection(TERRAFORM_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, TERRAFORM_SECTION);

  const allPatterns = patterns.map((p) => ({
    slug: p.id.replace(/\.md$/, '').split('/')[1],
    title: p.data.title,
    category: p.data.category,
    intent: p.data.intent,
    summary: getPatternSummary(p),
    relatedSlugs: p.data.relatedSlugs,
  }));

  return patterns.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').split('/')[1];
    return {
      params: { category: entry.data.category, slug },
      props: {
        pattern: {
          slug,
          title: entry.data.title,
          category: entry.data.category,
          intent: entry.data.intent,
          summary: getPatternSummary(entry),
          relatedSlugs: entry.data.relatedSlugs,
          basePath: TERRAFORM_SECTION.basePath,
        },
        markdown: entry.body,
        allPatterns,
        navOrder,
      },
    };
  });
}

const { pattern, markdown, allPatterns, navOrder } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  name: `${pattern.title} Pattern in Terraform`,
  description: pattern.intent,
  url: `https://intentionalcode.com${TERRAFORM_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`,
  publisher: { '@type': 'Organization', name: 'Intentional Code' },
};
---

<SiteLayout
  title={pattern.title}
  description={pattern.intent}
  jsonLd={jsonLd}
  basePath={TERRAFORM_SECTION.basePath}
  sectionLabel={TERRAFORM_SECTION.label}
  themeStorageKey={TERRAFORM_SECTION.themeStorageKey}
  categoryOrder={TERRAFORM_SECTION.categoryOrder}
  philosophyOrder={TERRAFORM_SECTION.philosophyOrder}
  collections={TERRAFORM_SECTION.collections}
>
  <PatternPage
    pattern={pattern}
    markdown={markdown}
    allPatterns={allPatterns}
    navOrder={navOrder}
    pathname={`${TERRAFORM_SECTION.basePath}/patterns/${pattern.category}/${pattern.slug}`}
    client:load
  />
</SiteLayout>
