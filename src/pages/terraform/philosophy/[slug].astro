---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import PhilosophyDetailPage from '@/components/pages/PhilosophyDetailPage';
import { buildNavOrder } from '@/lib/site-data';
import { TERRAFORM_SECTION } from '@/lib/section-config';

export async function getStaticPaths() {
  const [patterns, philosophy, categories] = await Promise.all([
    getCollection(TERRAFORM_SECTION.collections.patterns),
    getCollection(TERRAFORM_SECTION.collections.philosophy),
    getCollection(TERRAFORM_SECTION.collections.categories),
  ]);

  const navOrder = buildNavOrder(patterns, philosophy, categories, TERRAFORM_SECTION);

  return philosophy.filter((entry) => entry.id !== 'index').map((entry) => {
    const slug = entry.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: {
        slug,
        title: entry.data.title,
        description: entry.data.description,
        markdown: entry.body,
        navOrder,
      },
    };
  });
}

const { slug, title, description, markdown, navOrder } = Astro.props;
---

<SiteLayout
  title={title}
  description={description}
  basePath={TERRAFORM_SECTION.basePath}
  sectionLabel={TERRAFORM_SECTION.label}
  themeStorageKey={TERRAFORM_SECTION.themeStorageKey}
  categoryOrder={TERRAFORM_SECTION.categoryOrder}
  philosophyOrder={TERRAFORM_SECTION.philosophyOrder}
  collections={TERRAFORM_SECTION.collections}
>
  <PhilosophyDetailPage
    slug={slug}
    title={title}
    description={description}
    markdown={markdown}
    navOrder={navOrder}
    pathname={`${TERRAFORM_SECTION.basePath}/philosophy/${slug}`}
    client:load
  />
</SiteLayout>
