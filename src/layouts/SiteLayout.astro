---
import { getCollection } from 'astro:content';
import TopBar from '@/components/layout/TopBar';
import Sidebar from '@/components/layout/Sidebar';
import { buildNavData, buildNavOrder, buildSearchData } from '@/lib/site-data';
import { GO_SECTION } from '@/lib/section-config';
import Footer from '@/components/layout/Footer.astro';
import '@/index.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  jsonLd?: object;
  basePath?: string;
  homePath?: string;
  sectionLabel?: string;
  themeStorageKey?: string;
  categoryOrder?: string[];
  philosophyOrder?: string[];
  collections?: {
    patterns: string;
    philosophy: string;
    categories: string;
    pages?: string;
  };
}

const {
  title,
  description,
  canonical,
  jsonLd,
  basePath = GO_SECTION.basePath,
  homePath = GO_SECTION.homePath ?? GO_SECTION.basePath,
  sectionLabel = GO_SECTION.label,
  themeStorageKey = GO_SECTION.themeStorageKey,
  categoryOrder = GO_SECTION.categoryOrder,
  philosophyOrder = GO_SECTION.philosophyOrder,
  collections = GO_SECTION.collections,
} = Astro.props;

const siteTitle = title ? `${title} | Intentional Code` : `Intentional Code with ${sectionLabel}`;
const canonicalUrl = canonical ?? `https://intentionalcode.com${Astro.url.pathname}`;

const [patterns, philosophy, categories] = await Promise.all([
  getCollection(collections.patterns),
  getCollection(collections.philosophy),
  getCollection(collections.categories),
]);

const navData = buildNavData(patterns, categories, { categoryOrder });
const navOrder = buildNavOrder(patterns, philosophy, categories, { basePath, homePath, categoryOrder, philosophyOrder });
const searchData = buildSearchData(patterns, philosophy, categories, { basePath });
const philosophyItems = philosophy
  .filter((entry) => entry.id !== 'index')
  .sort((a, b) => philosophyOrder.indexOf(a.id) - philosophyOrder.indexOf(b.id))
  .map((entry) => ({ slug: entry.id.replace(/\.md$/, ''), title: entry.data.title }));
const pathname = Astro.url.pathname;
const sectionKey = basePath.replace(/^\//, '') || 'go';
---

<!doctype html>
<html lang="en" data-section={sectionKey}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://intentionalcode.com/og-image.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://intentionalcode.com/og-image.png" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-269QQ6RJW6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-269QQ6RJW6');
    </script>
    <script is:inline define:vars={{ themeStorageKey }}>
      (function () {
        var t = localStorage.getItem(themeStorageKey);
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        if (t === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <TopBar
      searchData={searchData}
      pathname={pathname}
      basePath={basePath}
      homePath={homePath}
      sectionLabel={sectionLabel}
      themeStorageKey={themeStorageKey}
      client:load
    />
    <div class="flex flex-1">
      <Sidebar
        navData={navData}
        navOrder={navOrder}
        pathname={pathname}
        basePath={basePath}
        homePath={homePath}
        sectionLabel={sectionLabel}
        philosophyItems={philosophyItems}
        client:load
      />
      <main class="flex-1 min-w-0">
        <slot />
      </main>
    </div>
    <Footer basePath={basePath} categoryOrder={categoryOrder} />
  </body>
</html>
