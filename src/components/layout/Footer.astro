---
interface Props {
  basePath?: string;
  categoryOrder?: string[];
  courses?: { slug: string; title: string }[];
}

const {
  basePath = '/go',
  categoryOrder = ['creational', 'structural', 'behavioral', 'architectural', 'concurrency'],
  courses = [],
} = Astro.props;

const year = new Date().getFullYear();

const patternLinks = categoryOrder.map((cat) => ({
  label: cat.charAt(0).toUpperCase() + cat.slice(1),
  href: `${basePath}/patterns/${cat}`,
}));

const courseLinks = courses.length
  ? [
      { label: 'All courses', href: `${basePath}/courses` },
      ...courses.map((course) => ({ label: course.title, href: `${basePath}/courses/${course.slug}` })),
    ]
  : [];

const exploreLinks = [
  { label: 'Philosophy', href: `${basePath}/philosophy` },
  { label: 'Pattern Finder', href: `${basePath}/finder` },
  { label: 'Saved Patterns', href: `${basePath}/saved` },
];
---

<footer class="border-t border-border bg-background">
  <div class="max-w-screen-xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Wordmark + description -->
      <div class="sm:col-span-1">
        <a href="/" class="inline-flex items-center gap-0.5 mb-3 select-none">
          <span class="font-bold text-sm tracking-tight text-foreground">Intentional Code</span>
          <span class="text-primary font-bold text-sm">_</span>
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Design patterns and principles, implemented in idiomatic Go — with examples, tradeoffs, and cross-references.
        </p>
      </div>

      <!-- Patterns links -->
      <div>
        <h3 class="text-xs font-semibold text-foreground uppercase tracking-widest mb-4">Patterns</h3>
        <ul class="space-y-2.5">
          {patternLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Courses links -->
      {courseLinks.length > 0 && (
        <div>
          <h3 class="text-xs font-semibold text-foreground uppercase tracking-widest mb-4">Practice</h3>
          <ul class="space-y-2.5">
            {courseLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Explore links -->
      <div>
        <h3 class="text-xs font-semibold text-foreground uppercase tracking-widest mb-4">Explore</h3>
        <ul class="space-y-2.5">
          {exploreLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs text-muted-foreground">
        &copy; {year} Intentional Code
      </p>
      <p class="text-xs text-muted-foreground">
        Built for engineers who want to write code that lasts.
      </p>
    </div>
  </div>
</footer>
